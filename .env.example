# ---- Server-side env (NOT VITE_-prefixed → never shipped to the browser) ----
# Copy to `.env` for local `vercel dev`, and set the same vars in the Vercel
# dashboard (Project → Settings → Environment Variables) for production.

# Admin login
ADMIN_USERNAME=admin
# scrypt hash of the password, format "salt:hash" (both hex).
# Generate it (real value) with:  node scripts/hash-password.mjs 'your-password'
ADMIN_PASSWORD_HASH=
# Random secret used to sign the session cookie.
# Generate with:  node scripts/gen-secret.mjs
SESSION_SECRET=

# ---- Storage: Upstash Redis (products) ----
# Auto-injected when you connect an Upstash/KV store in the Vercel dashboard.
# (Locally, paste them from the Upstash console.)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ---- Storage: Vercel Blob (media uploads) ----
# Auto-injected when you create a Blob store in the Vercel dashboard.
BLOB_READ_WRITE_TOKEN=
