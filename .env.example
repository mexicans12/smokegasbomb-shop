# ---- Server-side env (NOT VITE_-prefixed -- never shipped to the browser) ----
# Copy to `.env` for local `vercel dev`, and set the same vars in the Vercel
# dashboard (Project -- Settings -- Environment Variables) for production.

# Admin login
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
# Random secret used to sign the session cookie.
# Generate with:  node scripts/gen-secret.mjs
SESSION_SECRET=

# ---- Storage: Upstash Redis (products) ----
# Auto-injected when you connect an Upstash/KV store in the Vercel dashboard.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ---- Storage: ImageKit (media uploads -- images + video) ----
# From the ImageKit dashboard (Settings -- Developer options -- API keys).
# IMAGEKIT_PRIVATE_KEY is server-only; IMAGEKIT_PUBLIC_KEY is returned to the
# browser only to sign client-side uploads (never used for management calls).
IMAGEKIT_PUBLIC_KEY=
IMAGEKIT_PRIVATE_KEY=
IMAGEKIT_URL_ENDPOINT=
